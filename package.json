{
  "name": "vscode-changelists",
  "displayName": "Git Changelists",
  "description": "JetBrains-style git changelists for VSCode. Group working-tree changes into changelists and commit only the ones you choose.",
  "version": "0.1.1",
  "publisher": "jaroros",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jarorosFork/vscode-changelists.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "changelists",
          "title": "Changelists",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "changelists": [
        {
          "id": "changelists.view",
          "name": "Changelists",
          "contextualTitle": "Changelists"
        }
      ]
    },
    "configuration": {
      "title": "Changelists",
      "properties": {
        "changelists.pullStrategy": {
          "type": "string",
          "enum": ["merge", "rebase"],
          "enumDescriptions": [
            "Merge the incoming changes into the current branch (creates a merge commit if diverged).",
            "Rebase the current branch on top of the incoming changes (linear history, rewrites local commits)."
          ],
          "default": "merge",
          "description": "How the Pull button reconciles your branch with its upstream when they've diverged. Equivalent to JetBrains' \"Update Method\" setting — Pull always fetches then explicitly merges or rebases, so it never depends on your global git pull.rebase/pull.ff configuration."
        }
      }
    },
    "commands": [
      {
        "command": "changelists.updateFromBranch",
        "title": "Update from Branch...",
        "category": "Changelists",
        "icon": "$(git-merge)"
      },
      {
        "command": "changelists.pull",
        "title": "Pull",
        "category": "Changelists",
        "icon": "$(arrow-down)"
      },
      {
        "command": "changelists.push",
        "title": "Push",
        "category": "Changelists",
        "icon": "$(arrow-up)"
      },
      {
        "command": "changelists.refresh",
        "title": "Refresh",
        "category": "Changelists",
        "icon": "$(refresh)"
      },
      {
        "command": "changelists.createChangelist",
        "title": "New Changelist...",
        "category": "Changelists",
        "icon": "$(add)"
      },
      {
        "command": "changelists.renameChangelist",
        "title": "Rename Changelist...",
        "category": "Changelists",
        "icon": "$(edit)"
      },
      {
        "command": "changelists.deleteChangelist",
        "title": "Delete Changelist",
        "category": "Changelists",
        "icon": "$(trash)"
      },
      {
        "command": "changelists.setActiveChangelist",
        "title": "Set as Active Changelist",
        "category": "Changelists",
        "icon": "$(check)"
      },
      {
        "command": "changelists.commitSelected",
        "title": "Commit Selected...",
        "category": "Changelists",
        "icon": "$(check)"
      },
      {
        "command": "changelists.moveToChangelist",
        "title": "Move to Changelist...",
        "category": "Changelists",
        "icon": "$(arrow-right)"
      },
      {
        "command": "changelists.addToChangelist",
        "title": "Add to Changelist...",
        "category": "Changelists",
        "icon": "$(add)"
      },
      {
        "command": "changelists.commitChangelist",
        "title": "Commit Changelist...",
        "category": "Changelists",
        "icon": "$(check-all)"
      },
      {
        "command": "changelists.rollbackChangelist",
        "title": "Rollback Changelist...",
        "category": "Changelists",
        "icon": "$(discard)"
      },
      {
        "command": "changelists.rollbackChange",
        "title": "Rollback...",
        "category": "Changelists",
        "icon": "$(discard)"
      },
      {
        "command": "changelists.showDiff",
        "title": "Show Diff",
        "category": "Changelists",
        "icon": "$(diff)"
      },
      {
        "command": "changelists.showChangelistDiff",
        "title": "Show Diff",
        "category": "Changelists",
        "icon": "$(diff-multiple)"
      },
      {
        "command": "changelists.openChange",
        "title": "Open File",
        "category": "Changelists",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "changelists.pull",
          "when": "view == changelists.view && !changelists.multiRepo",
          "group": "navigation@1"
        },
        {
          "command": "changelists.push",
          "when": "view == changelists.view && !changelists.multiRepo",
          "group": "navigation@2"
        },
        {
          "command": "changelists.commitChangelist",
          "when": "view == changelists.view && !changelists.multiRepo",
          "group": "navigation@3"
        },
        {
          "command": "changelists.createChangelist",
          "when": "view == changelists.view && !changelists.multiRepo",
          "group": "navigation@4"
        },
        {
          "command": "changelists.refresh",
          "when": "view == changelists.view",
          "group": "navigation@5"
        },
        {
          "command": "changelists.updateFromBranch",
          "when": "view == changelists.view && !changelists.multiRepo",
          "group": "1_sync@1"
        }
      ],
      "view/item/context": [
        {
          "command": "changelists.pull",
          "when": "view == changelists.view && viewItem == repo",
          "group": "inline@1"
        },
        {
          "command": "changelists.pull",
          "when": "view == changelists.view && viewItem == repo",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.push",
          "when": "view == changelists.view && viewItem == repo",
          "group": "inline@2"
        },
        {
          "command": "changelists.push",
          "when": "view == changelists.view && viewItem == repo",
          "group": "1_actions@2"
        },
        {
          "command": "changelists.createChangelist",
          "when": "view == changelists.view && viewItem == repo",
          "group": "inline@3"
        },
        {
          "command": "changelists.createChangelist",
          "when": "view == changelists.view && viewItem == repo",
          "group": "1_actions@3"
        },
        {
          "command": "changelists.updateFromBranch",
          "when": "view == changelists.view && viewItem == repo",
          "group": "1_actions@4"
        },
        {
          "command": "changelists.commitChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "inline@1"
        },
        {
          "command": "changelists.setActiveChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.commitChangelist",
          "when": "view == changelists.view && viewItem =~ /changelist/",
          "group": "1_actions@2"
        },
        {
          "command": "changelists.rollbackChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "1_actions@3"
        },
        {
          "command": "changelists.showChangelistDiff",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "inline@2"
        },
        {
          "command": "changelists.showChangelistDiff",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "1_actions@4"
        },
        {
          "command": "changelists.renameChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "2_edit@1"
        },
        {
          "command": "changelists.deleteChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "2_edit@2"
        },
        {
          "command": "changelists.showDiff",
          "when": "view == changelists.view && (viewItem == change || viewItem == unversioned-change)",
          "group": "inline@0"
        },
        {
          "command": "changelists.showDiff",
          "when": "view == changelists.view && (viewItem == change || viewItem == unversioned-change)",
          "group": "3_open@1"
        },
        {
          "command": "changelists.openChange",
          "when": "view == changelists.view && (viewItem == change || viewItem == unversioned-change)",
          "group": "3_open@2"
        },
        {
          "command": "changelists.commitSelected",
          "when": "view == changelists.view && viewItem == change",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.moveToChangelist",
          "when": "view == changelists.view && viewItem == change",
          "group": "inline@1"
        },
        {
          "command": "changelists.moveToChangelist",
          "when": "view == changelists.view && viewItem == change",
          "group": "1_actions@2"
        },
        {
          "command": "changelists.rollbackChange",
          "when": "view == changelists.view && viewItem == change",
          "group": "inline@2"
        },
        {
          "command": "changelists.rollbackChange",
          "when": "view == changelists.view && viewItem == change",
          "group": "1_actions@3"
        },
        {
          "command": "changelists.addToChangelist",
          "when": "view == changelists.view && viewItem == unversioned-change",
          "group": "inline@1"
        },
        {
          "command": "changelists.addToChangelist",
          "when": "view == changelists.view && viewItem == unversioned-change",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.rollbackChange",
          "when": "view == changelists.view && viewItem == unversioned-change",
          "group": "1_actions@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
