{
  "name": "vscode-changelists",
  "displayName": "Git Changelists",
  "description": "JetBrains-style git changelists for VSCode. Group working-tree changes into changelists and commit only the ones you choose.",
  "version": "0.0.10",
  "publisher": "jaroros",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jarorosFork/vscode-changelists.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "changelists",
          "title": "Changelists",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "changelists": [
        {
          "id": "changelists.view",
          "name": "Changelists",
          "contextualTitle": "Changelists"
        }
      ]
    },
    "commands": [
      {
        "command": "changelists.pull",
        "title": "Pull",
        "category": "Changelists",
        "icon": "$(arrow-down)"
      },
      {
        "command": "changelists.push",
        "title": "Push",
        "category": "Changelists",
        "icon": "$(arrow-up)"
      },
      {
        "command": "changelists.refresh",
        "title": "Refresh",
        "category": "Changelists",
        "icon": "$(refresh)"
      },
      {
        "command": "changelists.createChangelist",
        "title": "New Changelist...",
        "category": "Changelists",
        "icon": "$(add)"
      },
      {
        "command": "changelists.renameChangelist",
        "title": "Rename Changelist...",
        "category": "Changelists",
        "icon": "$(edit)"
      },
      {
        "command": "changelists.deleteChangelist",
        "title": "Delete Changelist",
        "category": "Changelists",
        "icon": "$(trash)"
      },
      {
        "command": "changelists.setActiveChangelist",
        "title": "Set as Active Changelist",
        "category": "Changelists",
        "icon": "$(check)"
      },
      {
        "command": "changelists.moveToChangelist",
        "title": "Move to Changelist...",
        "category": "Changelists",
        "icon": "$(arrow-right)"
      },
      {
        "command": "changelists.addToChangelist",
        "title": "Add to Changelist...",
        "category": "Changelists",
        "icon": "$(add)"
      },
      {
        "command": "changelists.commitChangelist",
        "title": "Commit Changelist...",
        "category": "Changelists",
        "icon": "$(check-all)"
      },
      {
        "command": "changelists.rollbackChangelist",
        "title": "Rollback Changelist...",
        "category": "Changelists",
        "icon": "$(discard)"
      },
      {
        "command": "changelists.rollbackChange",
        "title": "Rollback...",
        "category": "Changelists",
        "icon": "$(discard)"
      },
      {
        "command": "changelists.showDiff",
        "title": "Show Diff",
        "category": "Changelists",
        "icon": "$(diff)"
      },
      {
        "command": "changelists.openChange",
        "title": "Open File",
        "category": "Changelists",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "changelists.pull",
          "when": "view == changelists.view",
          "group": "navigation@1"
        },
        {
          "command": "changelists.push",
          "when": "view == changelists.view",
          "group": "navigation@2"
        },
        {
          "command": "changelists.commitChangelist",
          "when": "view == changelists.view",
          "group": "navigation@3"
        },
        {
          "command": "changelists.createChangelist",
          "when": "view == changelists.view",
          "group": "navigation@4"
        },
        {
          "command": "changelists.refresh",
          "when": "view == changelists.view",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "changelists.commitChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "inline@1"
        },
        {
          "command": "changelists.setActiveChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.commitChangelist",
          "when": "view == changelists.view && viewItem =~ /changelist/",
          "group": "1_actions@2"
        },
        {
          "command": "changelists.rollbackChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "1_actions@3"
        },
        {
          "command": "changelists.renameChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "2_edit@1"
        },
        {
          "command": "changelists.deleteChangelist",
          "when": "view == changelists.view && viewItem == changelist",
          "group": "2_edit@2"
        },
        {
          "command": "changelists.showDiff",
          "when": "view == changelists.view && viewItem =~ /change/",
          "group": "inline@0"
        },
        {
          "command": "changelists.showDiff",
          "when": "view == changelists.view && viewItem =~ /change/",
          "group": "3_open@1"
        },
        {
          "command": "changelists.openChange",
          "when": "view == changelists.view && viewItem =~ /change/",
          "group": "3_open@2"
        },
        {
          "command": "changelists.moveToChangelist",
          "when": "view == changelists.view && viewItem == change",
          "group": "inline@1"
        },
        {
          "command": "changelists.moveToChangelist",
          "when": "view == changelists.view && viewItem == change",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.rollbackChange",
          "when": "view == changelists.view && viewItem == change",
          "group": "inline@2"
        },
        {
          "command": "changelists.rollbackChange",
          "when": "view == changelists.view && viewItem == change",
          "group": "1_actions@2"
        },
        {
          "command": "changelists.addToChangelist",
          "when": "view == changelists.view && viewItem == unversioned-change",
          "group": "inline@1"
        },
        {
          "command": "changelists.addToChangelist",
          "when": "view == changelists.view && viewItem == unversioned-change",
          "group": "1_actions@1"
        },
        {
          "command": "changelists.rollbackChange",
          "when": "view == changelists.view && viewItem == unversioned-change",
          "group": "1_actions@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
